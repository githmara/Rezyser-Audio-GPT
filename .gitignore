# --- ŚRODOWISKO I BIBLIOTEKI ---
# Ignorujemy ciężki folder runtime (lokalny Python), którego nie wysyłamy na GitHub 
runtime/
# Ignorujemy wirtualne środowiska tworzone przez deweloperów
venv/
.venv/
env/

# --- PLIKI TYMCZASOWE I CACHE ---
# Czyścimy cache Pythona we wszystkich podfolderach (również w /pages) 
__pycache__/
*.pyc
# Pliki tymczasowe tłumacza
temp_*.jsonl

# --- DANE UŻYTKOWNIKA I KLUCZE (KRYTYCZNE) ---
# Folder ze skryptami i historiami użytkownika 
skrypty/
# Klucz API i pliki środowiskowe (nigdy nie publikujemy!) 
*.env
golden_key.env

# --- HISTORYCZNE WZORCE STREAMLIT (USUNIĘTE) ---
# Te pliki zostały usunięte w ramach migracji na wxPython.
# Wpisy tu zapobiegają przypadkowemu ponownemu dodaniu.
Start.py
pages/

# --- ARTEFAKTY WYDANIA (BUILD) ---
# Ignorujemy gotowe paczki ZIP i instalatory EXE, by nie zaśmiecać repozytorium
*.zip
*.exe
# Launcher end-user jest generowany przez build_release.py — nie wersjonujemy go w repo.
# (W wersjach 11.x–13.0 ten plik nazywał się `Uruchom_Rezysera.bat`; został
# przemianowany w 13.1 razem z resztą skryptów infrastruktury na angielskie
# nazwy. Historyczny plik nadal może się walać na dyskach deweloperów,
# którzy zbudowali starsze paczki lokalnie — stąd poniżej zostaje również
# stary wzorzec, żeby `git status` ich nie dziwił.)
run.bat
Uruchom_Rezysera.bat


# --- USTAWIENIA EDYTORA ---
.vscode/
.cline/
# Folder konfiguracyjny Claude Code (ustawienia, hooki, settings.local.json) —
# czysto deweloperski artefakt, nigdy nie ląduje w paczce produkcyjnej.
# Wykluczany analogicznie w build_release.py::IGNOROWANE_FOLDERY oraz w
# installer.iss::Excludes — trzymamy spójność wszystkich trzech miejsc.
/.claude/